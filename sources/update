#!/bin/bash

update () {
    # BUG FIX: antes solo bajaba update.sh si NO existia ya, quedando
    # con una copia vieja/rota para siempre si un intento anterior fallo.
    wget -q -O "$HOME/update.sh" \
        "https://raw.githubusercontent.com/JotchuaDevz/TeleBotGen/master/update.sh"

    if [[ ! -s "$HOME/update.sh" ]]; then
        local bot_retorno="$LINE\n"
        bot_retorno+="❌ No se pudo descargar update.sh\n"
        bot_retorno+="$LINE\n"
        msj_fun
        return 1
    fi

    chmod +x "$HOME/update.sh"

    # BUG FIX: antes usaba screen + killall BotGen.sh, que no mataba
    # el proceso real (corre como 'bash' bajo systemd) y terminaba
    # duplicando el bot. update.sh ahora reinicia el servicio el mismo.
    nohup "$HOME/update.sh" >/dev/null 2>&1 &
}
